# Reference for S3 consumers (Ceph RGW)
# RGW on mgmt-storage listens via hostNetwork on port 80 — reachable at any
# mgmt-storage node IP. Consumer apps use these as env vars / SDK config.
apiVersion: v1
kind: ConfigMap
metadata:
  name: ceph-rgw-endpoint
  namespace: {{ item.consumer_namespace }}
data:
  endpoint: "http://{{ storage_node_ip }}"
  alt-endpoints: "http://10.10.4.100,http://10.10.4.101,http://10.10.4.102"
  note: |
    S3 credentials for the "admin" user are in the CephObjectStoreUser
    "admin-user" on the mgmt-storage cluster; fetch via:
      kubectl -n rook-ceph get secret rook-ceph-object-user-my-store-admin-user -o yaml
    and create a matching Secret in this namespace if needed.
