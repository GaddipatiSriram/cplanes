# -----------------------------------------------------------------------------
# Helm — downloaded subchart tarballs + lockfiles are regenerated by Argo
# -----------------------------------------------------------------------------
**/charts/*.tgz
**/charts/*.tar.gz
**/Chart.lock

# -----------------------------------------------------------------------------
# Secrets — admin passwords, SMTP creds, PagerDuty keys belong in Vault
# -----------------------------------------------------------------------------
values-secret.yaml
values-secrets.yaml
*.decrypted
*.pem
*.key
!**/templates/*.yaml

