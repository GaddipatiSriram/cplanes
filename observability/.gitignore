# Claude Code
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# OS & editor
# -----------------------------------------------------------------------------
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# -----------------------------------------------------------------------------
# Logs & temp
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
