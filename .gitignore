# Secrets — never commit
# Be EXPLICIT about which filenames are credential files; broad patterns
# (e.g. **/*-secret-*.yaml) accidentally catch legitimate chart templates
# like cluster-secret-store.yaml.
**/forge-secret-sre.yaml
**/forge-secret-devops.yaml
**/layers-secret-sre.yaml
**/layers-secret-devops.yaml
**/cplanes-secret-sre.yaml
**/cplanes-secret-devops.yaml
**/storage-repo-secret.yaml
**/cluster-secret.yaml
**/argocd-cluster-*.yaml
**/*-creds.yaml
**/*-creds.yml

# File-extension-based — keys, certs, kubeconfigs, env files
**/*.pat
**/*.pem
**/*.key
**/*.crt
**/*.kubeconfig
**/kubeconfig-*
.env
.env.*

# Helm artifacts
**/charts/
**/Chart.lock
**/*.tgz

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Claude Code agent state
.claude/
**/.claude/

# Local-only operator state
*.local.yaml
*.local.yml
